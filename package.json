{
  "name": "claude-ping-pong",
  "version": "0.1.0",
  "description": "Local Markdown review tool with inline comments for Claude agents",
  "type": "module",
  "bin": {
    "claude-ping-pong": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.node.json && vite build",
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "start": "node dist/server/index.js",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.node.json"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.9.1",
    "chokidar": "^4.0.3",
    "citty": "^0.2.2",
    "hono": "^4.7.6",
    "nanoid": "^5.1.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-rehype": "^11.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vite": "^6.2.5",
    "vitest": "^4.1.2"
  },
  "volta": {
    "node": "24.14.1"
  }
}
